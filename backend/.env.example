# Server configuration port (default: 5001)
PORT=5001

# GitHub Personal Access Token (for live data queries).
# Leave blank or unconfigured to automatically use high-fidelity Demo Mode.
GITHUB_TOKEN=your_personal_access_token_here

# Google Gemini API key (free tier) for the AI Code Analyzer
GEMINI_API_KEY=your_gemini_api_key_here

